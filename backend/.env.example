PORT=5000
NODE_ENV=production

# Local MongoDB on the same VPS (default database name if unset in code)
MONGO_URI=mongodb://127.0.0.1:27017/testing_unotrips_crm

JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=30d

# Comma-separated allowed frontend origins
CORS_ORIGINS=https://testing.unotrips.com,http://localhost:5173

SEED_PASSWORD=123456

# Optional — shared cache across PM2 workers (falls back to in-memory if unavailable)
REDIS_URL=redis://127.0.0.1:6379
