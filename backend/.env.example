PORT=5000
NODE_ENV=production

# Local MongoDB on the same VPS (default database name if unset in code)
MONGO_URI=mongodb://127.0.0.1:27017/testing_unotrips_crm

JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=30d

# Comma-separated allowed frontend origins
CORS_ORIGINS=https://testing.unotrips.com,http://localhost:5173

SEED_PASSWORD=123456

# Optional — shared cache across PM2 workers (falls back to in-memory if unavailable)
REDIS_URL=redis://127.0.0.1:6379

# Enterprise email (Nodemailer) — sender: sales@unotrips.com
# Hostinger: use port 465 (implicit TLS; secure is auto-detected)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=sales@unotrips.com
SMTP_PASS=
SMTP_FROM_NAME=UNO Trips

# Email reply tracking (IMAP — defaults to SMTP credentials if unset)
# IMAP_HOST=imap.hostinger.com
# IMAP_PORT=993
# IMAP_USER=sales@unotrips.com
# IMAP_PASS=
# EMAIL_INBOX_POLL_MS=300000

# Uno Hotels package catalog (quotation builder)
UNO_HOTELS_API_BASE_URL=https://unohotels-backend.onrender.com
# Use admin Package Control API (recommended). Set token OR email/password:
# UNO_HOTELS_ADMIN_TOKEN=
# UNO_HOTELS_ADMIN_EMAIL=
# UNO_HOTELS_ADMIN_PASSWORD=
