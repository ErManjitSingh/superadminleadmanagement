PORT=5000
NODE_ENV=production

# Local MongoDB on the same VPS (default database name if unset in code)
MONGO_URI=mongodb://127.0.0.1:27017/indiaholidaydestination_crm

JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=30d

# Super Admin (separate auth — use a different secret in production)
SUPERADMIN_JWT_SECRET=change-this-superadmin-secret-in-production
SUPERADMIN_JWT_EXPIRES_IN=8h
SUPERADMIN_EMAIL=superadmin@indiaholidaydestination.com
SUPERADMIN_PASSWORD=SuperAdmin@123

# CRM frontend URL for impersonation redirects
CRM_FRONTEND_URL=http://localhost:5173

# Multi-tenant subdomain base domain
PLATFORM_DOMAIN=indiaholidaydestination.com
# Custom domain DNS verification (optional)
APP_CNAME_TARGET=proxy.indiaholidaydestination.com
SERVER_IP=
# Auto SSL via certbot when custom domain DNS is verified (VPS only)
SSL_AUTO_PROVISION=false
SSL_ADMIN_EMAIL=admin@indiaholidaydestination.com

# Comma-separated allowed frontend origins
CORS_ORIGINS=https://indiaholidaydestination.com,http://localhost:5173,http://localhost:5174

SEED_PASSWORD=123456

# Optional — shared cache across PM2 workers (falls back to in-memory if unavailable)
REDIS_URL=redis://127.0.0.1:6379

# Enterprise email (Nodemailer)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=sales@indiaholidaydestination.com
SMTP_PASS=
SMTP_FROM_NAME=Travel CRM

# Email reply tracking (IMAP — defaults to SMTP credentials if unset)
# IMAP_HOST=imap.hostinger.com
# IMAP_PORT=993
# IMAP_USER=sales@unotrips.com
# IMAP_PASS=
# EMAIL_INBOX_POLL_MS=300000

# Uno Hotels package catalog (quotation builder)
UNO_HOTELS_API_BASE_URL=https://unohotels-backend.onrender.com

# AI Itinerary Generator (Package & Quotation builder)
# Google Gemini (recommended) — get key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-key-here
# GEMINI_MODEL=gemini-2.5-flash
# AI_ITINERARY_PROVIDER=gemini

# OpenAI (alternative)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Use admin Package Control API (recommended). Set token OR email/password:
# UNO_HOTELS_ADMIN_TOKEN=
# UNO_HOTELS_ADMIN_EMAIL=
# UNO_HOTELS_ADMIN_PASSWORD=
