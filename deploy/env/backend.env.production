# Copy to VPS:
#   cp deploy/env/backend.env.production /var/www/testing-unotrips-crm/backend/.env
# Then edit JWT_SECRET before going live.

PORT=5000
NODE_ENV=production

MONGO_URI=mongodb://127.0.0.1:27017/testing_unotrips_crm

JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRES_IN=30d

CORS_ORIGINS=https://testing.unotrips.com

SEED_PASSWORD=123456

REDIS_URL=redis://127.0.0.1:6379
